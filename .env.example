# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: URL of your Supabase project (for direct cloud synchronization)
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Public Anon Key of your Supabase project
SUPABASE_ANON_KEY=""

# FB_SYSTEM_USER_TOKEN: Facebook System User Token used for automated Page accounts synchronization
FB_SYSTEM_USER_TOKEN=""

# ADMIN_PASSWORD: Mật khẩu trang quản trị admin của Thanh Trà BĐS (Mặc định là 123456 nếu bỏ trống)
ADMIN_PASSWORD="123456"

# ==========================================
# CẤU HÌNH CLOUDINARY - HỆ THỐNG LƯU TRỮ VÀ TỐI ƯU HÌNH ẢNH TOÀN DIỆN
# ==========================================
# Ghi chú bảo mật: CLOUDINARY_API_SECRET và CLOUDINARY_API_KEY CHỈ được giữ ở Server (.env của Express) để tránh lộ khóa.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Biến môi trường cho Client (Vite) nếu cần cấu hình hiển thị hoặc upload trực tiếp từ client-side
VITE_CLOUDINARY_CLOUD_NAME=""

# GROQ_API_KEY: Khóa API dự phòng cho Chatbox AI từ hệ thống Groq
GROQ_API_KEY=""

# ==========================================
# CẤU HÌNH DÀNH CHO XUẤT KHẨU GITHUB / VERCEL / NETLIFY HOẶC HOSTING TĨNH
# Thiết lập các biến môi trường này trên Dashboard của Vercel/Netlify để Vite thay thế trực tiếp vào mã nguồn client-side khi biên dịch (build static)
# ==========================================
VITE_GEMINI_API_KEY=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
