{
  "redirects": [
    { "source": "/", "has": [{"type": "query", "key": "id"}], "destination": "/chitiet.html?id=:id" }
  ],
  "rewrites": [
    { "source": "/chitiet/:slug", "destination": "/chitiet.html" },
    { "source": "/:path(chitiet.html)", "destination": "/chitiet.html" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/robots.txt", "destination": "/api/robots" },
    { "source": "/((?!api/|assets/|sitemap.xml|robots.txt|35b5d3bca36c4c1dbe818a516f674d43.txt|favicon.svg|favicon.ico).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/((?!api/|assets/|sitemap.xml|robots.txt|35b5d3bca36c4c1dbe818a516f674d43.txt|favicon.svg|favicon.ico).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/sitemap.ts": {
      "maxDuration": 10
    }
  }
}